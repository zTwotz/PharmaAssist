  createdAt    DateTime   @default(now()) @map("created_at")
  aiAuditLog   AiAuditLog @relation(fields: [aiAuditLogId], references: [id], onDelete: Cascade)

  @@map("ai_guardrail_events")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     String   @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model GraphNode {
  id          Int         @id @default(autoincrement())
  nodeKey     String      @unique @map("node_key")
  label       String
  type        String
  description String?
  metadata    String?
  createdAt   DateTime    @default(now()) @map("created_at")
  edgesFrom   GraphEdge[] @relation("FromNode")
  edgesTo     GraphEdge[] @relation("ToNode")

  @@map("graph_nodes")
}

model GraphEdge {
  id         Int       @id @default(autoincrement())
  fromNodeId Int       @map("from_node_id")
  toNodeId   Int       @map("to_node_id")
  relation   String
  metadata   String?
  createdAt  DateTime  @default(now()) @map("created_at")
  fromNode   GraphNode @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode     GraphNode @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@map("graph_edges")
}

model GraphContextLog {
  id            Int      @id @default(autoincrement())
  orderId       Int?     @map("order_id")
  alertId       Int?     @map("alert_id")
  contextText   String   @map("context_text")
  usedByAiLogId Int?     @map("used_by_ai_log_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("graph_context_logs")
}

model ProductReview {
  id         Int           @id @default(autoincrement())
  productId  Int           @map("product_id")
  customerId Int           @map("customer_id")
  orderId    Int?          @map("order_id")
  rating     Int
  content    String
  status     String        @default("PENDING")
  createdAt  DateTime      @default(now()) @map("created_at")
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order      Order?        @relation(fields: [orderId], references: [id])
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  images     ReviewImage[]

  @@map("product_reviews")
}

model ReviewImage {
  id        Int           @id @default(autoincrement())
  reviewId  Int           @map("review_id")
  imageUrl  String        @map("image_url")
  createdAt DateTime      @default(now()) @map("created_at")
  review    ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_images")
}

model ProductQuestion {
  id         Int             @id @default(autoincrement())
  productId  Int             @map("product_id")
  customerId Int             @map("customer_id")
  question   String
  status     String          @default("PENDING")
  createdAt  DateTime        @default(now()) @map("created_at")
  answers    ProductAnswer[]
  customer   Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_questions")
}

model ProductAnswer {
  id         Int             @id @default(autoincrement())
  questionId Int             @map("question_id")
  answeredBy String          @map("answered_by")
  answer     String
  createdAt  DateTime        @default(now()) @map("created_at")
  question   ProductQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("product_answers")
}

model Banner {
  id        Int      @id @default(autoincrement())
  title     String
  imageUrl  String   @map("image_url")
  linkUrl   String?  @map("link_url")
  position  String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("banners")
}

model Article {
  id           Int             @id @default(autoincrement())
  categoryId   Int             @map("category_id")
  title        String
  slug         String          @unique
  summary      String?
  content      String
  thumbnailUrl String?         @map("thumbnail_url")
  authorId     String          @map("author_id") @db.Uuid
  status       String          @default("DRAFT")
  publishedAt  DateTime?       @map("published_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  author       User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category     ArticleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("articles")
}

model ArticleCategory {
  id          Int               @id @default(autoincrement())
  name        String
  slug        String            @unique
  description String?
  parentId    Int?              @map("parent_id")
  status      String            @default("ACTIVE")
  createdAt   DateTime          @default(now()) @map("created_at")
  parent      ArticleCategory?  @relation("ArticleCategoryHierarchy", fields: [parentId], references: [id])
  children    ArticleCategory[] @relation("ArticleCategoryHierarchy")
  articles    Article[]

  @@map("article_categories")
}
