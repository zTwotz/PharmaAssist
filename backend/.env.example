# Application
NODE_ENV=development
APP_NAME=PharmaAssist AI Intelligence
PORT=3001
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=debug

# PostgreSQL / Prisma
DATABASE_URL=
DIRECT_URL=

# Supabase
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Neo4j AuraDB
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_CONNECTION_TIMEOUT_MS=10000
NEO4J_QUERY_TIMEOUT_MS=5000

# Knowledge Graph
GRAPH_SYNC_ENABLED=false
GRAPH_RAG_ENABLED=false
VECTOR_SEARCH_ENABLED=false
GRAPH_FALLBACK_TO_POSTGRES=true
GRAPH_STALE_AFTER_MINUTES=60
GRAPH_RAG_TOP_K=5
GRAPH_RAG_MAX_CONTEXT_LENGTH=8000

# AI
AI_PROVIDER=mock
AI_FALLBACK_PROVIDER=mock
AI_TIMEOUT_MS=15000
AI_MAX_RETRIES=2
AI_LOG_PROMPT=false
AI_LOG_RESPONSE=false

# Gemini
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=
GEMINI_EMBEDDING_MODEL=

# Guardrail
AI_GUARDRAIL_ENABLED=true
AI_REQUIRE_DISCLAIMER=true
AI_ALLOW_DIAGNOSIS=false
AI_ALLOW_PRESCRIPTION=false

# Payment
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=
PAYMENT_RETURN_URL=http://localhost:3000/payment/result
PAYMENT_CANCEL_URL=http://localhost:3000/payment/cancel
PAYMENT_TIMEOUT_MS=15000

# Upload
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,application/pdf

# Security
REQUEST_ID_HEADER=x-request-id
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
